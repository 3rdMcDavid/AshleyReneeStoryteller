---
const year = new Date().getFullYear();
---

<footer class="bg-[#2d2926] text-[#e8e4de] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="flex flex-col items-start">
        <img src="/images/logo/logo.jpg" alt="Ashley Renee Photography" class="h-14 w-auto mb-4" />
        <p class="font-['Jost'] text-sm text-[#a09890] leading-relaxed max-w-xs">
          Capturing genuine moments and timeless emotions — from wedding days to everyday life.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-['Jost'] text-[10px] tracking-[0.25em] uppercase text-[#c4a882] mb-5">Explore</h4>
        <nav class="flex flex-col gap-3">
          {[
            { label: 'About Ashley', href: '/about' },
            { label: 'Portfolio', href: '/portfolio' },
            { label: 'Investment', href: '/investment' },
            { label: 'Blog', href: '/blog' },
            { label: 'Contact', href: '/contact' },
          ].map(link => (
            <a href={link.href} class="font-['Jost'] text-sm text-[#a09890] hover:text-[#c4a882] transition-colors duration-200">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact & Social -->
      <div>
        <h4 class="font-['Jost'] text-[10px] tracking-[0.25em] uppercase text-[#c4a882] mb-5">Connect</h4>
        <p class="font-['Jost'] text-sm text-[#a09890] mb-1">hello@ashleyreeneephoto.com</p>
        <p class="font-['Jost'] text-sm text-[#a09890] mb-6">Based in [Your City], available worldwide</p>
        <div class="flex gap-4">
          <a href="#" aria-label="Instagram" class="text-[#a09890] hover:text-[#c4a882] transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"></circle>
            </svg>
          </a>
          <a href="#" aria-label="Facebook" class="text-[#a09890] hover:text-[#c4a882] transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a href="#" aria-label="Pinterest" class="text-[#a09890] hover:text-[#c4a882] transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.77 1.28-5.43 1.28-5.43s-.33-.65-.33-1.62c0-1.52.88-2.65 1.97-2.65.93 0 1.38.7 1.38 1.54 0 .94-.6 2.34-.91 3.64-.26 1.09.54 1.97 1.6 1.97 1.92 0 3.21-2.45 3.21-5.35 0-2.21-1.49-3.76-3.61-3.76-2.46 0-3.9 1.84-3.9 3.75 0 .74.28 1.54.64 1.97.07.08.08.16.06.24l-.24.97c-.04.15-.13.18-.3.11-1.11-.52-1.81-2.14-1.81-3.44 0-2.8 2.03-5.37 5.85-5.37 3.07 0 5.46 2.19 5.46 5.11 0 3.05-1.92 5.5-4.58 5.5-.89 0-1.74-.46-2.03-1.01l-.55 2.07c-.2.77-.74 1.73-1.1 2.32.83.26 1.71.4 2.62.4 5.52 0 10-4.48 10-10S17.52 2 12 2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-[#3d3330] pt-6 text-center">
      <p class="font-['Jost'] text-xs text-[#7a7470] tracking-wider">
        &copy; {year} Ashley Renee Photography. All rights reserved.
      </p>
    </div>
  </div>
</footer>
