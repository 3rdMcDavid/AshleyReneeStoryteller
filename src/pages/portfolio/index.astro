---
import Layout from '../../layouts/Layout.astro';

const categories = [
  {
    title: 'Weddings',
    href: '/portfolio/weddings',
    image: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=80',
    count: '200+ sessions',
    description: 'Full-day wedding coverage filled with emotion, elegance, and authentic moments.',
  },
  {
    title: 'Engagements',
    href: '/portfolio/engagements',
    image: 'https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=800&q=80',
    count: '150+ sessions',
    description: 'Celebrate your love story before the big day.',
  },
  {
    title: 'Senior Portraits',
    href: '/portfolio/senior-portraits',
    image: 'https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=800&q=80',
    count: '300+ seniors',
    description: 'Confident, authentic portraits that mark this incredible milestone.',
  },
  {
    title: 'Family',
    href: '/portfolio/family',
    image: 'https://images.unsplash.com/photo-1511895426328-dc8714191011?w=800&q=80',
    count: '500+ families',
    description: 'Real laughter, real connection — no stiff poses here.',
  },
  {
    title: 'Lifestyle',
    href: '/portfolio/lifestyle',
    image: 'https://images.unsplash.com/photo-1469371670807-013ccf25f16a?w=800&q=80',
    count: 'Ongoing',
    description: 'Everyday moments that deserve to be remembered beautifully.',
  },
  {
    title: 'Graduation',
    href: '/portfolio/graduation',
    image: 'https://images.unsplash.com/photo-1627556704302-624286467c65?w=800&q=80',
    count: 'All levels',
    description: 'Celebrate the hard work and the big achievement in style.',
  },
];
---

<Layout title="Portfolio | Ashley Renee Photography" description="Browse Ashley Renee's photography portfolio — weddings, engagements, senior portraits, family, and lifestyle sessions.">

  <!-- Page Hero -->
  <section class="relative h-[45vh] min-h-[360px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1600&q=80"
        alt="Portfolio"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/45"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-14 text-white">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-white/70 mb-2">Browse the Work</p>
      <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-7xl font-light">The Portfolio</h1>
    </div>
  </section>

  <!-- Category Grid -->
  <section class="py-16 px-6 bg-[#faf8f5]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {categories.map((cat, i) => (
          <a
            href={cat.href}
            class={`group relative overflow-hidden ${i === 4 ? 'md:col-span-2' : ''} aspect-[16/9]`}
          >
            <img
              src={cat.image}
              alt={cat.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
              <p class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#c4a882] mb-1">{cat.count}</p>
              <h3 class="font-['Cormorant_Garamond'] text-3xl font-light mb-2">{cat.title}</h3>
              <p class="font-['Jost'] text-sm text-white/70 max-w-md">{cat.description}</p>
              <span class="inline-block mt-4 font-['Jost'] text-[10px] tracking-[0.2em] uppercase border-b border-[#c4a882] pb-0.5 text-[#c4a882] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                View Gallery
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>
