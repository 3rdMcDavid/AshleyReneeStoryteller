---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: 'https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=800&q=80', alt: 'Senior portrait' },
  { src: 'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80', alt: 'Senior outdoors' },
  { src: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800&q=80', alt: 'Senior portrait close-up' },
  { src: 'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?w=800&q=80', alt: 'Senior in field' },
  { src: 'https://images.unsplash.com/photo-1517841905240-472988babdf9?w=800&q=80', alt: 'Senior natural light' },
  { src: 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=800&q=80', alt: 'Senior portrait sitting' },
  { src: 'https://images.unsplash.com/photo-1515378791036-0648a3ef77b2?w=800&q=80', alt: 'Senior lifestyle' },
  { src: 'https://images.unsplash.com/photo-1502823403499-6ccfcf4fb453?w=800&q=80', alt: 'Senior smiling' },
];
---

<Layout title="Senior Portraits | Ashley Renee Photography">
  <GalleryPage
    title="Senior Portraits"
    subtitle="Class of the Year"
    heroImage="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=1600&q=80"
    description="This is your moment — own it. Senior portraits should feel as confident, unique, and real as you are. No cookie-cutter poses here."
    images={images}
  />
</Layout>
