---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: 'https://images.unsplash.com/photo-1511895426328-dc8714191011?w=800&q=80', alt: 'Family portrait' },
  { src: 'https://images.unsplash.com/photo-1484863137850-59afcfe05386?w=800&q=80', alt: 'Family outdoors' },
  { src: 'https://images.unsplash.com/photo-1474552226712-ac0f0961a954?w=800&q=80', alt: 'Family laughing' },
  { src: 'https://images.unsplash.com/photo-1516627145497-ae6968895b74?w=800&q=80', alt: 'Parents with children' },
  { src: 'https://images.unsplash.com/photo-1444723121867-7a241cacace9?w=800&q=80', alt: 'Family in nature' },
  { src: 'https://images.unsplash.com/photo-1491013516836-7db643ee125a?w=800&q=80', alt: 'Family candid' },
  { src: 'https://images.unsplash.com/photo-1562765780-56cf0f95b85b?w=800&q=80', alt: 'Family moment' },
  { src: 'https://images.unsplash.com/photo-1560969184-10fe8719e047?w=800&q=80', alt: 'Family in sunset' },
];
---

<Layout title="Family | Ashley Renee Photography">
  <GalleryPage
    title="Family"
    subtitle="Real Moments"
    heroImage="https://images.unsplash.com/photo-1511895426328-dc8714191011?w=1600&q=80"
    description="Family photos aren't about perfection — they're about connection. I'll give you the prompts, you bring the people, and together we'll make something you'll hang on your wall for years."
    images={images}
  />
</Layout>
