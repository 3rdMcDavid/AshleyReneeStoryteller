---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: '/images/family/DSC01882.jpg', alt: 'Family' },
  { src: '/images/family/DSC02170.jpg', alt: 'Family' },
  { src: '/images/family/DSC01803.jpg', alt: 'Family' },
  { src: '/images/family/DSC08052-Edit.jpg', alt: 'Family' },
  { src: '/images/family/DSC08383.jpg', alt: 'Family' },
  { src: '/images/family/DSC09520.jpg', alt: 'Family' },
  { src: '/images/family/DSC09607.jpg', alt: 'Family' },
  { src: '/images/family/DSC09723.jpg', alt: 'Family' },
  { src: '/images/family/DSC09474.jpg', alt: 'Family' },
