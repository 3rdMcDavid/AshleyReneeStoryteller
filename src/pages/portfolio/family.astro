---

<Layout title="Family | Ashley Renee Photography">
  <GalleryPage
    title="Family"
    subtitle="Real Moments"
    heroImage="/images/family/DSC01803.jpg"
    description="Family photos aren't about perfection — they're about connection. I'll give you the prompts, you bring the people, and together we'll make something you'll hang on your wall for years."
    images={images}
  />
</Layout>
