  { src: '/images/graduation/469961676_18040704251192102_1640981002278873645_n.jpg', alt: 'Graduation' },
  { src: '/images/graduation/486422654_18051434111192102_7004594492906745869_n.jpg', alt: 'Graduation' },
  { src: '/images/graduation/487523014_18051534053192102_1089375369083583276_n.jpg', alt: 'Graduation' },
  { src: '/images/graduation/488534172_18052253276192102_7044977378075307248_n.jpg', alt: 'Graduation' },
