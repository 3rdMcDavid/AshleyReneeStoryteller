---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: '/images/senior/DSC00937.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00636.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC_3246.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00546.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00628.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00727.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00808.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC00882-2.jpg', alt: 'Graduation' },
  { src: '/images/senior/DSC01006.jpg', alt: 'Graduation' },
