---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: 'https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=800&q=80', alt: 'Wedding ceremony' },
  { src: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=80', alt: 'Wedding couple' },
  { src: 'https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=800&q=80', alt: 'Wedding details' },
  { src: 'https://images.unsplash.com/photo-1546032996-6dfacbacbf3f?w=800&q=80', alt: 'Wedding reception' },
  { src: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=800&q=80', alt: 'First dance' },
  { src: 'https://images.unsplash.com/photo-1591604466107-ec97de577aff?w=800&q=80', alt: 'Wedding rings' },
  { src: 'https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=800&q=80', alt: 'Bride portrait' },
  { src: 'https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=800&q=80', alt: 'Couple portrait' },
  { src: 'https://images.unsplash.com/photo-1501901609772-df0848060b33?w=800&q=80', alt: 'Wedding venue' },
];
---

<Layout title="Weddings | Ashley Renee Photography">
  <GalleryPage
    title="Weddings"
    subtitle="Full Day Coverage"
    heroImage="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1600&q=80"
    description="Every wedding day is its own world — full of carefully planned moments and beautifully unplanned ones. I'm there for all of it."
    images={images}
  />
</Layout>
