---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: '/images/family/476511666_18046876553192102_5969360109962782845_n.jpg', alt: 'In-home newborn session' },
  { src: '/images/family/476889152_18046876526192102_4843740009865742826_n.jpg', alt: 'In-home newborn session' },
];
---

<Layout title="In-Home Newborn | Ashley Renee Photography">
  <GalleryPage
    title="In-Home Newborn"
    subtitle="Welcome Home"
    heroImage="/images/family/476511666_18046876553192102_5969360109962782845_n.jpg"
    description="The first days at home are fleeting and irreplaceable. Let me come to you and capture the quiet, tender moments of your new beginning — right where they happen."
    images={images}
  />
</Layout>
