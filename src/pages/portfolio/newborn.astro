---
import Layout from '../../layouts/Layout.astro';
import GalleryPage from '../../components/GalleryPage.astro';

const images = [
  { src: '/images/newborn/DSC08889.jpg', alt: 'In-home newborn session' },
  { src: '/images/newborn/DSC09154.jpg', alt: 'In-home newborn session' },
  { src: '/images/newborn/DSC09107.jpg', alt: 'In-home newborn session' },
  { src: '/images/newborn/DSC09100.jpg', alt: 'In-home newborn session' },
  { src: '/images/newborn/DSC09006.jpg', alt: 'In-home newborn session' },
];
---

<Layout title="In-Home Newborn | Ashley Renee Photography">
  <GalleryPage
    title="In-Home Newborn"
    subtitle="Welcome Home"
    heroImage="/images/newborn/DSC09154.jpg"
    description="The first days at home are fleeting and irreplaceable. Let me come to you and capture the quiet, tender moments of your new beginning — right where they happen."
    images={images}
  />
</Layout>
