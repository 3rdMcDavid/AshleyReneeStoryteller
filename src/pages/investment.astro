---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Investment | Ashley Renee Photography" description="Photography investment and pricing for weddings, elopements, couples, maternity, newborn, and grad sessions.">

  <!-- Page Hero -->
  <section class="relative h-[45vh] min-h-[360px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/weddings/657386617_1555531319912080_4977176062089839949_n.jpg"
        alt="Investment"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-14 text-white">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-white/70 mb-2">Pricing & Packages</p>
      <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-7xl font-light">Investment</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 px-6 bg-[#faf8f5] text-center">
    <div class="max-w-2xl mx-auto">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4">What to Expect</p>
      <h2 class="font-['Cormorant_Garamond'] text-4xl font-light text-[#2d2926] mb-6">
        Photographs you'll pass down for generations
      </h2>
      <div class="w-12 h-px bg-[#c4a882] mx-auto mb-6"></div>
      <p class="font-['Jost'] text-sm text-[#7a7470] leading-relaxed">
        All packages include beautifully edited, high-resolution images delivered through a private online gallery. Every investment includes a full print release so you can print, share, and display your images anywhere, forever.
      </p>
    </div>
  </section>

  <!-- Weddings -->
  <section class="pb-20 px-6 bg-[#faf8f5]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-['Cormorant_Garamond'] text-3xl font-light text-[#2d2926] text-center mb-12">Weddings</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

        <!-- Elopements -->
        <div class="bg-white border border-[#e8e4de] p-10 flex flex-col">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">Intimate & Adventurous</p>
          <h3 class="font-['Cormorant_Garamond'] text-3xl font-light text-[#2d2926] mb-3">Elopements</h3>
          <div class="w-8 h-px bg-[#e8e4de] mb-5"></div>
          <p class="font-['Cormorant_Garamond'] text-5xl text-[#2d2926] mb-1">$400</p>
          <p class="font-['Jost'] text-xs text-[#c4a882] tracking-widest uppercase mb-8">Starting at</p>
          <a href="/contact" class="mt-auto text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3.5 border border-[#2d2926] text-[#2d2926] hover:bg-[#2d2926] hover:text-white transition-all duration-300">
            Inquire
          </a>
        </div>

        <!-- Weddings -->
        <div class="bg-white border border-[#c4a882] p-10 flex flex-col shadow-lg relative">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">4, 6, or 8 Hours</p>
          <h3 class="font-['Cormorant_Garamond'] text-3xl font-light text-[#2d2926] mb-3">Weddings</h3>
          <div class="w-8 h-px bg-[#e8e4de] mb-5"></div>
          <p class="font-['Cormorant_Garamond'] text-5xl text-[#2d2926] mb-1">$600</p>
          <p class="font-['Jost'] text-xs text-[#c4a882] tracking-widest uppercase mb-8">Starting at</p>
          <a href="/contact" class="mt-auto text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3.5 bg-[#c4a882] text-white hover:bg-[#a08660] transition-all duration-300">
            Inquire
          </a>
        </div>

      </div>

      <!-- All Wedding Packages Include -->
      <div class="bg-white border border-[#e8e4de] p-10">
        <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4 text-center">All Wedding Packages Include</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            'Engagement session',
            'Bridal session',
            '1 photographer',
            '500+ images',
            'High-resolution download',
            'Full print release',
          ].map(item => (
            <div class="flex items-start gap-3">
              <span class="text-[#c4a882] mt-0.5 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </span>
              <span class="font-['Jost'] text-sm text-[#7a7470]">{item}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Portraits & Lifestyle -->
  <section class="pb-20 px-6 bg-[#faf8f5]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-['Cormorant_Garamond'] text-3xl font-light text-[#2d2926] text-center mb-12">Portraits & Lifestyle</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">

        <!-- Couples -->
        <div class="bg-white border border-[#e8e4de] p-8 flex flex-col">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">45 min – 1 hr</p>
          <h3 class="font-['Cormorant_Garamond'] text-2xl font-light text-[#2d2926] mb-3">Couples</h3>
          <div class="w-6 h-px bg-[#e8e4de] mb-4"></div>
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$275</p>
          <p class="font-['Jost'] text-[10px] text-[#c4a882] tracking-widest uppercase mb-5">Per session</p>
          <p class="font-['Jost'] text-xs text-[#7a7470] mb-8 flex-1">25+ edited images</p>
          <a href="/contact" class="text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3 border border-[#2d2926] text-[#2d2926] hover:bg-[#2d2926] hover:text-white transition-all duration-300">
            Book
          </a>
        </div>

        <!-- Maternity -->
        <div class="bg-white border border-[#e8e4de] p-8 flex flex-col">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">1 Hour</p>
          <h3 class="font-['Cormorant_Garamond'] text-2xl font-light text-[#2d2926] mb-3">Maternity</h3>
          <div class="w-6 h-px bg-[#e8e4de] mb-4"></div>
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$300</p>
          <p class="font-['Jost'] text-[10px] text-[#c4a882] tracking-widest uppercase mb-5">Per session</p>
          <p class="font-['Jost'] text-xs text-[#7a7470] mb-8 flex-1">25+ edited images</p>
          <a href="/contact" class="text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3 border border-[#2d2926] text-[#2d2926] hover:bg-[#2d2926] hover:text-white transition-all duration-300">
            Book
          </a>
        </div>

        <!-- In-Home Newborn -->
        <div class="bg-white border border-[#e8e4de] p-8 flex flex-col">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">2 Hours</p>
          <h3 class="font-['Cormorant_Garamond'] text-2xl font-light text-[#2d2926] mb-3">In-Home Newborn</h3>
          <div class="w-6 h-px bg-[#e8e4de] mb-4"></div>
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$400</p>
          <p class="font-['Jost'] text-[10px] text-[#c4a882] tracking-widest uppercase mb-5">Per session</p>
          <p class="font-['Jost'] text-xs text-[#7a7470] mb-8 flex-1">25+ edited images</p>
          <a href="/contact" class="text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3 border border-[#2d2926] text-[#2d2926] hover:bg-[#2d2926] hover:text-white transition-all duration-300">
            Book
          </a>
        </div>

        <!-- Grads -->
        <div class="bg-white border border-[#e8e4de] p-8 flex flex-col">
          <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-2">Milestone</p>
          <h3 class="font-['Cormorant_Garamond'] text-2xl font-light text-[#2d2926] mb-3">Grads</h3>
          <div class="w-6 h-px bg-[#e8e4de] mb-4"></div>
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$200</p>
          <p class="font-['Jost'] text-[10px] text-[#c4a882] tracking-widest uppercase mb-5">Starting at</p>
          <p class="font-['Jost'] text-xs text-[#7a7470] mb-8 flex-1">Custom packages available</p>
          <a href="/contact" class="text-center font-['Jost'] text-xs tracking-[0.2em] uppercase py-3 border border-[#2d2926] text-[#2d2926] hover:bg-[#2d2926] hover:text-white transition-all duration-300">
            Book
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Add-Ons -->
  <section class="pb-20 px-6 bg-[#f5f1eb]">
    <div class="max-w-5xl mx-auto pt-16">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4 text-center">Enhance Your Experience</p>
      <h2 class="font-['Cormorant_Garamond'] text-3xl font-light text-[#2d2926] text-center mb-2">Add-Ons</h2>
      <div class="w-12 h-px bg-[#c4a882] mx-auto mb-12"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Content Creation -->
        <div class="bg-white border border-[#e8e4de] p-8">
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$200</p>
          <div class="w-6 h-px bg-[#e8e4de] my-4"></div>
          <h3 class="font-['Cormorant_Garamond'] text-xl font-light text-[#2d2926] mb-3">Content Creation</h3>
          <p class="font-['Jost'] text-xs text-[#7a7470] leading-relaxed">Behind-the-scenes content for social media, delivered alongside your gallery.</p>
        </div>

        <!-- Ceremony Video -->
        <div class="bg-white border border-[#e8e4de] p-8">
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$200</p>
          <div class="w-6 h-px bg-[#e8e4de] my-4"></div>
          <h3 class="font-['Cormorant_Garamond'] text-xl font-light text-[#2d2926] mb-3">Ceremony Video</h3>
          <p class="font-['Jost'] text-xs text-[#7a7470] leading-relaxed">Raw, unedited ceremony footage — a beautiful keepsake of your vows exactly as they happened.</p>
        </div>

        <!-- Wedding Website -->
        <div class="bg-white border border-[#e8e4de] p-8">
          <p class="font-['Cormorant_Garamond'] text-4xl text-[#2d2926] mb-1">$200</p>
          <div class="w-6 h-px bg-[#e8e4de] my-4"></div>
          <h3 class="font-['Cormorant_Garamond'] text-xl font-light text-[#2d2926] mb-3">Wedding Website</h3>
          <p class="font-['Jost'] text-xs text-[#7a7470] leading-relaxed">A custom site for your guests — QR code photo uploads, planning portal, and info on accommodations, food, and itineraries.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 bg-[#faf8f5] text-center">
    <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-3">Have Questions?</p>
    <h2 class="font-['Cormorant_Garamond'] text-4xl font-light text-[#2d2926] mb-4">Let's Chat</h2>
    <p class="font-['Jost'] text-sm text-[#7a7470] mb-8 max-w-md mx-auto">
      Every session is a little different. Reach out and let's find the perfect package for your vision and budget.
    </p>
    <a href="/contact" class="inline-block bg-[#2d2926] text-white font-['Jost'] text-xs tracking-[0.2em] uppercase px-10 py-4 hover:bg-[#c4a882] transition-all duration-300">
      Get in Touch
    </a>
  </section>

</Layout>
