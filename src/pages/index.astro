---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    title: 'Weddings',
    href: '/portfolio/weddings',
    image: '/images/weddings/469798149_18040705739192102_8132496887184357160_n.jpg',
    description: 'Timeless wedding stories told with heart.',
  },
  {
    title: 'Engagements',
    href: '/portfolio/engagements',
    image: '/images/engagement/139539768_226766872373739_100681518762178239_n.jpg',
    description: 'Celebrate your love before the big day.',
  },
  {
    title: 'Family',
    href: '/portfolio/family',
    image: '/images/family/114741042_145740437143050_6758810298093628763_n.jpg',
    description: 'Real moments, real connections.',
  },
  {
    title: 'Lifestyle',
    href: '/portfolio/lifestyle',
    image: '/images/lifestyle/103389046_129975188719575_8777935371690369010_n.jpg',
    description: 'Authentic stories in natural light.',
  },
  {
    title: 'Graduation',
    href: '/portfolio/graduation',
    image: '/images/graduation/469930142_18040703321192102_4301264534118079220_n.jpg',
    description: 'Celebrate the hard work and the big achievement.',
  },
];

const testimonials = [
  {
    name: 'Emily & James',
    role: 'Wedding Clients',
    quote: 'Ashley captured every little detail of our wedding day perfectly. Looking at the photos brings us right back to that magical day. We couldn\'t have asked for a better photographer.',
    initials: 'EJ',
  },
  {
    name: 'Sarah M.',
    role: 'Portrait Client',
    quote: 'I was so nervous in front of the camera, but Ashley made me feel completely at ease. My photos turned out absolutely beautiful — I will treasure them forever.',
    initials: 'SM',
  },
  {
    name: 'The Johnson Family',
    role: 'Family Session',
    quote: 'We have tried other photographers before but none compare to Ashley. She has a gift for capturing the real us — laughing, playing, just being a family.',
    initials: 'JF',
  },
];
---

<Layout title="Ashley Renee Photography | Wedding & Portrait Photographer">

  <!-- Hero -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/weddings/657386617_1555531319912080_4977176062089839949_new.jpg"
        alt="Wedding photography hero"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>
    <div class="relative z-10 text-center text-white px-6">
      <p class="font-['Jost'] text-xs tracking-[0.35em] uppercase text-white/80 mb-4">Welcome to</p>
      <h1 class="font-['Great_Vibes'] text-6xl md:text-8xl mb-3">Ashley Renee</h1>
      <p class="font-['Jost'] text-xs tracking-[0.35em] uppercase text-white/80 mb-8">Photography</p>
      <p class="font-['Cormorant_Garamond'] text-xl md:text-2xl italic font-light text-white/90 max-w-lg mx-auto mb-10">
        Capturing genuine moments & timeless emotions
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/portfolio" class="inline-block bg-white text-[#2d2926] font-['Jost'] text-xs tracking-[0.2em] uppercase px-8 py-3.5 hover:bg-[#c4a882] hover:text-white transition-all duration-300">
          View Portfolio
        </a>
        <a href="/contact" class="inline-block border border-white text-white font-['Jost'] text-xs tracking-[0.2em] uppercase px-8 py-3.5 hover:bg-white hover:text-[#2d2926] transition-all duration-300">
          Let's Connect
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/60">
      <span class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase">Scroll</span>
      <div class="w-px h-10 bg-white/40 animate-pulse"></div>
    </div>
  </section>

  <!-- Intro / Tagline -->
  <section class="py-24 px-6 text-center bg-[#faf8f5]">
    <div class="max-w-2xl mx-auto">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4">A little about the work</p>
      <h2 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-light leading-snug text-[#2d2926] mb-6">
        Every photo tells a story.<br />Let's tell yours.
      </h2>
      <div class="w-12 h-px bg-[#c4a882] mx-auto mb-6"></div>
      <p class="font-['Jost'] text-sm text-[#7a7470] leading-relaxed">
        From the quiet moments before a ceremony to the laughter of a family afternoon, I believe the most beautiful images are the ones that feel real. My approach is gentle, unobtrusive, and always rooted in connection.
      </p>
    </div>
  </section>

  <!-- Category Grid -->
  <section class="py-4 px-6 bg-[#faf8f5]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-3">The Portfolio</p>
        <h2 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-light text-[#2d2926]">What I Photograph</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map((cat, i) => (
          <a
            href={cat.href}
            class={`group relative overflow-hidden ${i === 0 ? 'md:col-span-2 lg:col-span-1' : ''} aspect-[4/5]`}
          >
            <img
              src={cat.image}
              alt={cat.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent transition-opacity duration-300 group-hover:opacity-90"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <h3 class="font-['Cormorant_Garamond'] text-2xl font-light mb-1">{cat.title}</h3>
              <p class="font-['Jost'] text-xs text-white/70 tracking-wide mb-3">{cat.description}</p>
              <span class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase border-b border-[#c4a882] pb-0.5 text-[#c4a882] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                View Gallery
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-24 px-6 bg-[#f5f1eb]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img
          src="/images/lifestyle/469843244_18040707203192102_6649566582940736998_n.jpg"
          alt="Ashley Renee, photographer"
          class="w-full aspect-[3/4] object-cover"
        />
        <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-[#c4a882]/20 -z-10"></div>
      </div>
      <div>
        <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4">Meet Ashley</p>
        <h2 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-light text-[#2d2926] mb-6 leading-snug">
          A photographer who<br />
          <em>genuinely loves people</em>
        </h2>
        <div class="w-12 h-px bg-[#c4a882] mb-6"></div>
        <p class="font-['Jost'] text-sm text-[#7a7470] leading-relaxed mb-4">
          Hi, I'm Ashley — and I believe every person, every couple, every family deserves photographs that make them feel something. I'm not just capturing a moment; I'm capturing who you are.
        </p>
        <p class="font-['Jost'] text-sm text-[#7a7470] leading-relaxed mb-8">
          Whether it's your wedding day, senior year, a lazy Sunday with your family, or just an afternoon that deserves to be remembered — I'm here for all of it.
        </p>
        <a href="/about" class="inline-block border border-[#2d2926] text-[#2d2926] font-['Jost'] text-xs tracking-[0.2em] uppercase px-8 py-3.5 hover:bg-[#2d2926] hover:text-white transition-all duration-300">
          More About Me
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 px-6 bg-[#faf8f5]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-3">Kind Words</p>
        <h2 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-light text-[#2d2926]">What Clients Are Saying</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white p-8 shadow-sm border border-[#e8e4de] flex flex-col">
            <p class="font-['Cormorant_Garamond'] text-lg italic text-[#4a4440] leading-relaxed mb-6 flex-1">
              "{t.quote}"
            </p>
            <div class="flex items-center gap-4 pt-4 border-t border-[#e8e4de]">
              <div class="w-10 h-10 rounded-full bg-[#c4a882] flex items-center justify-center flex-shrink-0">
                <span class="font-['Jost'] text-xs text-white font-medium">{t.initials}</span>
              </div>
              <div>
                <p class="font-['Jost'] text-sm font-medium text-[#2d2926]">{t.name}</p>
                <p class="font-['Jost'] text-xs text-[#c4a882] tracking-wide">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-32 px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/weddings/494374547_1254889969976218_7876590322570279490_n.jpg"
        alt="CTA background"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-[#2d2926]/75"></div>
    </div>
    <div class="relative z-10 text-center text-white max-w-2xl mx-auto">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4">Ready to Begin?</p>
      <h2 class="font-['Great_Vibes'] text-5xl md:text-7xl mb-6">Let's Make Something Beautiful</h2>
      <p class="font-['Jost'] text-sm text-white/70 leading-relaxed mb-10 max-w-md mx-auto">
        I'd love to hear about your story. Reach out and let's start planning your session.
      </p>
      <a href="/contact" class="inline-block bg-[#c4a882] text-white font-['Jost'] text-xs tracking-[0.2em] uppercase px-10 py-4 hover:bg-[#a08660] transition-all duration-300">
        Get in Touch
      </a>
    </div>
  </section>

</Layout>
