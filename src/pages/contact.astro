---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Ashley Renee Photography" description="Get in touch with Ashley Renee Photography to book your session or ask any questions.">

  <!-- Page Hero -->
  <section class="relative h-[45vh] min-h-[360px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=1600&q=80"
        alt="Contact"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-14 text-white">
      <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-white/70 mb-2">I'd Love to Hear From You</p>
      <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-7xl font-light">Let's Connect</h1>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 px-6 bg-[#faf8f5]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Info -->
      <div>
        <p class="font-['Jost'] text-[10px] tracking-[0.3em] uppercase text-[#c4a882] mb-4">Reach Out</p>
        <h2 class="font-['Cormorant_Garamond'] text-4xl font-light text-[#2d2926] mb-6 leading-snug">
          Ready to start planning? I'd love to hear about your vision.
        </h2>
        <div class="w-12 h-px bg-[#c4a882] mb-8"></div>

        <p class="font-['Jost'] text-sm text-[#7a7470] leading-relaxed mb-8">
          Whether you're planning a wedding, booking a senior portrait session, or just exploring your options — no question is too small. Fill out the form and I'll be in touch within 48 hours.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="text-[#c4a882] mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <p class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#c4a882] mb-1">Email</p>
              <p class="font-['Jost'] text-sm text-[#2d2926]">hello@ashleyreeneephoto.com</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="text-[#c4a882] mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <p class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#c4a882] mb-1">Location</p>
              <p class="font-['Jost'] text-sm text-[#2d2926]">[Your City, State]</p>
              <p class="font-['Jost'] text-xs text-[#7a7470]">Available for travel</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="text-[#c4a882] mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"></circle></svg>
            </div>
            <div>
              <p class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#c4a882] mb-1">Instagram</p>
              <p class="font-['Jost'] text-sm text-[#2d2926]">@ashleyreeneephoto</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white border border-[#e8e4de] p-8 md:p-10">
        <form class="space-y-6" name="contact" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="first-name">First Name</label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
                class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] focus:outline-none focus:border-[#c4a882] transition-colors"
              />
            </div>
            <div>
              <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="last-name">Last Name</label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                required
                class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] focus:outline-none focus:border-[#c4a882] transition-colors"
              />
            </div>
          </div>

          <div>
            <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] focus:outline-none focus:border-[#c4a882] transition-colors"
            />
          </div>

          <div>
            <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="session-type">Session Type</label>
            <select
              id="session-type"
              name="session-type"
              class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] focus:outline-none focus:border-[#c4a882] transition-colors appearance-none"
            >
              <option value="">Select a session type...</option>
              <option value="wedding">Wedding</option>
              <option value="engagement">Engagement</option>
              <option value="senior">Senior Portraits</option>
              <option value="family">Family</option>
              <option value="lifestyle">Lifestyle</option>
              <option value="other">Other / Not Sure Yet</option>
            </select>
          </div>

          <div>
            <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="date">Tentative Date</label>
            <input
              type="text"
              id="date"
              name="date"
              placeholder="e.g. September 2026 or unsure"
              class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] placeholder:text-[#b0aba5] focus:outline-none focus:border-[#c4a882] transition-colors"
            />
          </div>

          <div>
            <label class="font-['Jost'] text-[10px] tracking-[0.2em] uppercase text-[#7a7470] block mb-2" for="message">Tell Me About Your Vision</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Share any details you'd like — no message is too short or too long!"
              class="w-full border border-[#e8e4de] bg-[#faf8f5] px-4 py-3 font-['Jost'] text-sm text-[#2d2926] placeholder:text-[#b0aba5] focus:outline-none focus:border-[#c4a882] transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#2d2926] text-white font-['Jost'] text-xs tracking-[0.2em] uppercase py-4 hover:bg-[#c4a882] transition-all duration-300"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>
